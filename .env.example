# Secrets are managed via Infisical — run with: infisical run -- docker compose up -d
# This file documents the variable schema. Mirror these in your Infisical project.

# Postgres credentials (compose builds DATABASE_URL from these)
POSTGRES_USER=invosit
POSTGRES_PASSWORD=
POSTGRES_DB=invosit

# Dedicated least-privilege Postgres role for Kratos. Owns only the kratos
# database — keeps a compromised Kratos away from invosit application data.
# Per Ory: https://www.ory.com/docs/kratos/guides/deploy-kratos-example
KRATOS_DB_PASSWORD=                   # openssl rand -hex 32

# Ory Kratos
KRATOS_PUBLIC_URL=http://kratos:4433
KRATOS_WEBHOOK_SECRET=                # openssl rand -hex 32
# Per Ory's production guide, set all four secrets — don't rely on defaults.
# https://www.ory.com/docs/kratos/guides/production
KRATOS_DEFAULT_SECRET=                # openssl rand -hex 32
KRATOS_COOKIE_SECRET=                 # openssl rand -hex 32
KRATOS_CIPHER_SECRET=                 # exactly 32 chars (e.g. openssl rand -hex 16)
