
# Postgres credentials (compose builds DATABASE_URL from these)
POSTGRES_USER=invosit
POSTGRES_PASSWORD=
POSTGRES_DB=invosit


# Ory Kratos
# https://www.ory.com/docs/kratos/guides/production
KRATOS_DB_PASSWORD=

KRATOS_PUBLIC_URL=http://kratos:4433
KRATOS_WEBHOOK_SECRET=
KRATOS_DEFAULT_SECRET=
KRATOS_COOKIE_SECRET=
KRATOS_CIPHER_SECRET=                 # exactly 32 chars (e.g. openssl rand -hex 16)

# GitHub OAuth app for "Sign in with GitHub"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Blob storage
STORAGE_PROVIDER=r2                   # r2 | s3. r2 default
STORAGE_BUCKET=                       # e.g. invosit-blobs
STORAGE_ENDPOINT=                     # required for r2: https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=                       # leave blank for r2 (defaults to "auto")

# CORS. Comma-separated origins allowed to call /api/v1/*.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
